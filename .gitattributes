# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicit text
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.cjs      text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.vue      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.svg      text eol=lf

# Lockfiles: prevent diff noise
pnpm-lock.yaml      -diff linguist-generated=true
package-lock.json   -diff linguist-generated=true
yarn.lock           -diff linguist-generated=true

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.woff     binary
*.woff2    binary

# Exclude from GitHub language stats
dist/**            linguist-generated=true
docs/**            linguist-documentation=true
